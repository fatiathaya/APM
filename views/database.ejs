<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NeuroCare AI - Riwayat prediksi Alzheimer.">
    <title>Riwayat Prediksi - NeuroCare AI</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="bg-body-bg text-primary-dark font-outfit antialiased">
    <% const summaryData = (typeof summary !== 'undefined' && summary) ? summary : { total_predictions: 0, high_risk_count: 0, low_risk_count: 0 }; %>
    <% const recordList = (typeof records !== 'undefined' && records) ? records : []; %>
    <% const currentPage = (typeof page !== 'undefined') ? page : 1; %>
    <% const pagesTotal = (typeof totalPages !== 'undefined') ? totalPages : 1; %>
    <% const recordTotal = (typeof total !== 'undefined') ? total : 0; %>

    <nav class="glass-nav fixed top-0 left-0 w-full py-3.5 z-50">
        <div class="page-container-wide flex items-center justify-between">
            <a class="font-extrabold text-xl text-primary-blue flex items-center gap-2" href="/">
                <i class="bi bi-activity text-secondary-blue text-2xl"></i> NeuroCare AI
            </a>
            <div class="hidden md:flex items-center gap-6">
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all" href="/">Home</a>
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all"
                    href="/predict">Prediction</a>
                <a class="text-sm font-semibold text-primary-dark border-b-2 border-secondary-blue pb-0.5 transition-all"
                    href="/database">Riwayat</a>
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all"
                    href="/#about">About</a>
                <a class="btn-primary-gradient px-5 py-2 rounded-lg text-sm" href="/predict">Start Prediction</a>
            </div>
            <div class="md:hidden">
                <a class="btn-primary-gradient px-4 py-2 rounded-lg text-xs" href="/predict">Start Screening</a>
            </div>
        </div>
    </nav>

    <div class="pt-28 pb-6 hero-bg">
        <div class="page-container-wide">
            <span
                class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-600 text-[10px] font-bold px-3.5 py-1.5 rounded-full mb-3 uppercase tracking-wider">
                <i class="bi bi-clock-history"></i> Histori Prediksi
            </span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 mb-2">Riwayat Prediksi</h2>
            <p class="text-slate-500 text-sm max-w-2xl leading-relaxed">
                Daftar hasil prediksi Alzheimer dari form screening web. Setiap kali Anda submit form,
                hasilnya otomatis tersimpan di sini.
            </p>
        </div>
    </div>

    <section class="page-container-wide pb-16 space-y-6">

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">
            <div class="glass-card p-5 lg:p-6 rounded-xl text-center">
                <div class="text-2xl font-extrabold text-secondary-blue"><%= summaryData.total_predictions || 0 %></div>
                <div class="text-[11px] text-slate-500 font-semibold uppercase tracking-wide mt-1">Total Prediksi</div>
            </div>
            <div class="glass-card p-5 lg:p-6 rounded-xl text-center">
                <div class="text-2xl font-extrabold text-rose-600"><%= summaryData.high_risk_count || 0 %></div>
                <div class="text-[11px] text-slate-500 font-semibold uppercase tracking-wide mt-1">High Risk</div>
            </div>
            <div class="glass-card p-5 lg:p-6 rounded-xl text-center">
                <div class="text-2xl font-extrabold text-emerald-600"><%= summaryData.low_risk_count || 0 %></div>
                <div class="text-[11px] text-slate-500 font-semibold uppercase tracking-wide mt-1">Low Risk</div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <div class="p-4 border-b border-slate-100 bg-slate-50/50">
                <h3 class="font-bold text-slate-800 text-sm flex items-center gap-2">
                    <i class="bi bi-table text-secondary-blue"></i> Data Riwayat Prediksi
                </h3>
            </div>

            <div class="p-4 border-b border-slate-50">
                <p class="text-xs text-slate-500">
                    Menampilkan <span class="font-semibold text-slate-700"><%= recordList.length %></span>
                    dari <span class="font-semibold text-slate-700"><%= recordTotal %></span> prediksi
                    (halaman <%= currentPage %> / <%= pagesTotal %>)
                </p>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm min-w-[760px]">
                    <thead class="bg-slate-50 text-slate-500 uppercase tracking-wide">
                        <tr>
                            <th class="px-4 py-3 font-bold">No</th>
                            <th class="px-4 py-3 font-bold">Usia</th>
                            <th class="px-4 py-3 font-bold">Gender</th>
                            <th class="px-4 py-3 font-bold">MMSE</th>
                            <th class="px-4 py-3 font-bold">ADL</th>
                            <th class="px-4 py-3 font-bold">Hasil</th>
                            <th class="px-4 py-3 font-bold">Probabilitas</th>
                            <th class="px-4 py-3 font-bold">Status</th>
                            <th class="px-4 py-3 font-bold">Tanggal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (recordList.length === 0) { %>
                            <tr>
                                <td colspan="9" class="px-4 py-12 text-center text-slate-400">
                                    <i class="bi bi-inbox text-3xl block mb-3"></i>
                                    Belum ada riwayat prediksi.
                                    <a href="/predict" class="block mt-2 text-secondary-blue font-semibold hover:underline">
                                        Mulai screening sekarang
                                    </a>
                                </td>
                            </tr>
                        <% } else { %>
                            <% recordList.forEach(function(row) { %>
                                <tr class="hover:bg-slate-50/70 transition">
                                    <td class="px-4 py-3 font-semibold text-slate-800">#<%= row.id %></td>
                                    <td class="px-4 py-3"><%= row.age != null ? row.age + ' thn' : '-' %></td>
                                    <td class="px-4 py-3">
                                        <%= row.gender === 1 ? 'Laki-laki' : row.gender === 0 ? 'Perempuan' : '-' %>
                                    </td>
                                    <td class="px-4 py-3"><%= row.mmse != null ? Number(row.mmse).toFixed(1) : '-' %></td>
                                    <td class="px-4 py-3"><%= row.adl != null ? Number(row.adl).toFixed(1) : '-' %></td>
                                    <td class="px-4 py-3">
                                        <% if (row.is_high_risk) { %>
                                            <span class="inline-flex px-2 py-0.5 rounded-full bg-rose-50 text-rose-600 font-bold text-[10px]">High Risk</span>
                                        <% } else { %>
                                            <span class="inline-flex px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-600 font-bold text-[10px]">Low Risk</span>
                                        <% } %>
                                    </td>
                                    <td class="px-4 py-3 font-bold text-slate-800"><%= Number(row.probability_percentage).toFixed(1) %>%</td>
                                    <td class="px-4 py-3 text-slate-600"><%= row.status_text %></td>
                                    <td class="px-4 py-3 text-slate-500 whitespace-nowrap">
                                        <%= new Date(row.created_at).toLocaleString('id-ID') %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (pagesTotal > 1) { %>
                <div class="flex items-center justify-center gap-2 p-4 border-t border-slate-100 bg-slate-50/30">
                    <% if (currentPage > 1) { %>
                        <a href="/database?page=<%= currentPage - 1 %>"
                            class="px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 hover:border-secondary-blue hover:text-secondary-blue transition">
                            <i class="bi bi-chevron-left"></i> Sebelumnya
                        </a>
                    <% } %>

                    <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(pagesTotal, currentPage + 2); i++) { %>
                        <a href="/database?page=<%= i %>"
                            class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-bold transition <%= i === currentPage ? 'bg-secondary-blue text-white' : 'border border-slate-200 text-slate-600 hover:border-secondary-blue' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < pagesTotal) { %>
                        <a href="/database?page=<%= currentPage + 1 %>"
                            class="px-3 py-1.5 rounded-lg border border-slate-200 text-xs font-semibold text-slate-600 hover:border-secondary-blue hover:text-secondary-blue transition">
                            Selanjutnya <i class="bi bi-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            <% } %>
        </div>

        <div class="flex flex-wrap gap-3">
            <a href="/predict" class="btn-primary-gradient py-2.5 px-5 rounded-xl text-sm inline-flex items-center gap-2">
                <i class="bi bi-plus-circle"></i> Prediksi Baru
            </a>
        </div>
    </section>

    <footer class="bg-slate-950 text-slate-400 py-8">
        <div class="page-container-wide text-center text-xs">
            &copy; 2026 NeuroCare AI &mdash; Riwayat Prediksi
        </div>
    </footer>
</body>

</html>
