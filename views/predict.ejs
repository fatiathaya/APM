<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="NeuroCare AI - Alzheimer Prediction Input Form. Run XGBoost predictive screening model.">
    <title>Screening Form - NeuroCare AI</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="bg-body-bg text-primary-dark font-outfit antialiased overflow-x-hidden">

    <nav class="glass-nav fixed top-0 left-0 w-full py-3.5 z-50">
        <div class="page-container-wide flex items-center justify-between">
            <a class="font-extrabold text-xl text-primary-blue flex items-center gap-2" href="/">
                <i class="bi bi-activity text-secondary-blue text-2xl"></i> NeuroCare AI
            </a>
            <div class="hidden md:flex items-center gap-6">
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all" href="/">Home</a>
                <a class="text-sm font-semibold text-primary-dark border-b-2 border-secondary-blue pb-0.5 transition-all"
                    href="/predict">Prediction</a>
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all"
                    href="/database">Riwayat</a>
                <a class="text-sm font-medium text-slate-500 hover:text-secondary-blue transition-all"
                    href="/#about">About</a>
            </div>
            <div class="md:hidden">
                <a class="text-secondary-blue text-sm font-semibold" href="/database">Riwayat</a>
            </div>
        </div>
    </nav>

    <header class="pt-24 pb-8 hero-bg border-b border-slate-100/80">
        <div class="page-container-wide">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
                <div class="max-w-3xl">
                    <span
                        class="inline-flex items-center gap-1.5 bg-white/80 text-blue-600 text-[10px] font-bold px-3.5 py-1.5 rounded-full mb-3 uppercase tracking-wider border border-blue-100">
                        <i class="bi bi-clipboard2-pulse"></i> Predictive Analysis
                    </span>
                    <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight mb-2">
                        Alzheimer's Early Screening
                    </h1>
                    <p class="text-slate-500 text-sm md:text-base leading-relaxed">
                        Isi 4 langkah penilaian klinis di bawah. Form dirancang responsif agar mudah digunakan di desktop maupun mobile.
                    </p>
                </div>
                <div class="w-full lg:w-80 bg-white/80 backdrop-blur rounded-2xl border border-slate-100 p-4 shadow-sm">
                    <div class="flex items-center justify-between text-xs font-semibold text-slate-500 mb-2">
                        <span id="predictProgressText">Langkah 1 dari 4</span>
                        <span id="predictCurrentStepLabel">Demografi & Genetik</span>
                    </div>
                    <div class="h-2 rounded-full bg-slate-200 overflow-hidden">
                        <div id="predictProgressBar" class="h-full bg-gradient-to-r from-primary-blue to-secondary-blue rounded-full transition-all duration-300" style="width: 25%"></div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="page-container-wide py-8 pb-20">
        <form id="alzheimerPredictionForm" action="/result" method="POST" class="predict-shell">

            <aside class="predict-sidebar">
                <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400 mb-3 px-1">Navigasi Form</p>
                <div class="space-y-2">
                    <button type="button" class="predict-step-btn is-active" data-step-trigger="1" aria-current="step">
                        <span class="w-8 h-8 rounded-lg bg-blue-100 text-secondary-blue flex items-center justify-center text-sm font-bold shrink-0">1</span>
                        <span>
                            <span class="block text-sm font-bold">Demografi</span>
                            <span class="block text-[11px] text-slate-500">Usia, gender, riwayat keluarga</span>
                        </span>
                    </button>
                    <button type="button" class="predict-step-btn" data-step-trigger="2">
                        <span class="w-8 h-8 rounded-lg bg-slate-100 text-slate-500 flex items-center justify-center text-sm font-bold shrink-0">2</span>
                        <span>
                            <span class="block text-sm font-bold">Kognitif</span>
                            <span class="block text-[11px] text-slate-500">MMSE, ADL, fungsi kognitif</span>
                        </span>
                    </button>
                    <button type="button" class="predict-step-btn" data-step-trigger="3">
                        <span class="w-8 h-8 rounded-lg bg-slate-100 text-slate-500 flex items-center justify-center text-sm font-bold shrink-0">3</span>
                        <span>
                            <span class="block text-sm font-bold">Medis</span>
                            <span class="block text-[11px] text-slate-500">BMI, tekanan darah, penyakit</span>
                        </span>
                    </button>
                    <button type="button" class="predict-step-btn" data-step-trigger="4">
                        <span class="w-8 h-8 rounded-lg bg-slate-100 text-slate-500 flex items-center justify-center text-sm font-bold shrink-0">4</span>
                        <span>
                            <span class="block text-sm font-bold">Gaya Hidup</span>
                            <span class="block text-[11px] text-slate-500">Aktivitas, tidur, diet</span>
                        </span>
                    </button>
                </div>
            </aside>

            <div class="min-w-0 space-y-6">

                <!-- Step 1 -->
                <div class="predict-panel is-active" data-step-panel="1">
                    <div class="predict-card">
                        <div class="predict-card-header">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <i class="bi bi-person-badge-fill text-secondary-blue"></i>
                                    Demografi & Genetik
                                </h2>
                                <p class="text-xs text-slate-500 mt-1">Informasi dasar pasien dan faktor genetik.</p>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">3 field</span>
                        </div>
                        <div class="predict-card-body predict-grid-3">
                            <div>
                                <label for="age" class="form-label">Usia (Tahun)</label>
                                <input type="number" class="form-field" id="age" name="age" min="50" max="90" value="65" required>
                                <p class="form-hint">Rentang valid: 50 - 90 tahun.</p>
                            </div>
                            <div>
                                <label for="gender" class="form-label">Gender</label>
                                <select class="form-field" id="gender" name="gender" required>
                                    <option value="0">Perempuan</option>
                                    <option value="1">Laki-laki</option>
                                </select>
                                <p class="form-hint">Jenis kelamin biologis.</p>
                            </div>
                            <div class="sm:col-span-2 lg:col-span-1">
                                <label for="familyHistory" class="form-label">Riwayat Alzheimer Keluarga</label>
                                <select class="form-field" id="familyHistory" name="familyHistory" required>
                                    <option value="0">Tidak ada</option>
                                    <option value="1">Ada riwayat keluarga dekat</option>
                                </select>
                                <p class="form-hint">Kerabat dekat pernah didiagnosis Alzheimer.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="predict-panel" data-step-panel="2">
                    <div class="predict-card">
                        <div class="predict-card-header">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <i class="bi bi-brain text-secondary-blue"></i>
                                    Kognitif & Fungsional
                                </h2>
                                <p class="text-xs text-slate-500 mt-1">Skor kognitif dan kemampuan fungsional harian.</p>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">4 field</span>
                        </div>
                        <div class="predict-card-body space-y-5">
                            <div class="predict-grid-2">
                                <div>
                                    <label for="mmse" class="form-label">Skor MMSE</label>
                                    <input type="number" class="form-field" id="mmse" name="mmse" min="0" max="30" value="27" required>
                                    <p class="form-hint">Mini-Mental State Exam (0 - 30).</p>
                                </div>
                                <div>
                                    <label for="memoryComplaints" class="form-label">Keluhan Memori</label>
                                    <select class="form-field" id="memoryComplaints" name="memoryComplaints" required>
                                        <option value="0">Tidak ada</option>
                                        <option value="1">Ada keluhan memori</option>
                                    </select>
                                    <p class="form-hint">Keluhan subjektif penurunan memori.</p>
                                </div>
                            </div>
                            <div class="predict-grid-2">
                                <div class="range-container rounded-xl p-4 border border-slate-200 bg-slate-50/50">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="form-label mb-0">Skor ADL</span>
                                        <span id="valAdl" class="range-value-display text-xs">8.5</span>
                                    </div>
                                    <input type="range" class="w-full accent-secondary-blue h-1.5 cursor-pointer" id="adl" name="adl" min="0" max="10" step="0.1" value="8.5" data-value-display="valAdl">
                                    <div class="flex justify-between form-hint mt-2 mb-0"><span>0 Dependen</span><span>10 Mandiri</span></div>
                                </div>
                                <div class="range-container rounded-xl p-4 border border-slate-200 bg-slate-50/50">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="form-label mb-0">Functional Assessment</span>
                                        <span id="valFunc" class="range-value-display text-xs">7.8</span>
                                    </div>
                                    <input type="range" class="w-full accent-secondary-blue h-1.5 cursor-pointer" id="functionalAssessment" name="functionalAssessment" min="0" max="10" step="0.1" value="7.8" data-value-display="valFunc">
                                    <div class="flex justify-between form-hint mt-2 mb-0"><span>0 Parah</span><span>10 Normal</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="predict-panel" data-step-panel="3">
                    <div class="predict-card">
                        <div class="predict-card-header">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <i class="bi bi-heart-pulse-fill text-secondary-blue"></i>
                                    Riwayat Medis & Komposisi Tubuh
                                </h2>
                                <p class="text-xs text-slate-500 mt-1">Parameter klinis dan kondisi medis pasien.</p>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">10 field</span>
                        </div>
                        <div class="predict-card-body predict-grid-3">
                            <div>
                                <label for="bmi" class="form-label">BMI</label>
                                <input type="number" class="form-field" id="bmi" name="bmi" min="15" max="40" step="0.1" value="23.5" required>
                                <p class="form-hint">Rentang: 15.0 - 40.0</p>
                            </div>
                            <div>
                                <label for="cholesterolTotal" class="form-label">Kolesterol Total (mg/dL)</label>
                                <input type="number" class="form-field" id="cholesterolTotal" name="cholesterolTotal" min="150" max="300" step="0.1" value="200" required>
                                <p class="form-hint">Normal: 150-200 mg/dL</p>
                            </div>
                            <div>
                                <label for="systolicBP" class="form-label">Tekanan Sistolik</label>
                                <input type="number" class="form-field" id="systolicBP" name="systolicBP" min="90" max="180" value="120" required>
                                <p class="form-hint">Normal: 90-120 mmHg</p>
                            </div>
                            <div>
                                <label for="diastolicBP" class="form-label">Tekanan Diastolik</label>
                                <input type="number" class="form-field" id="diastolicBP" name="diastolicBP" min="60" max="120" value="80" required>
                                <p class="form-hint">Normal: 60-80 mmHg</p>
                            </div>
                            <div>
                                <label for="diabetes" class="form-label">Diabetes</label>
                                <select class="form-field" id="diabetes" name="diabetes" required>
                                    <option value="0">Tidak</option>
                                    <option value="1">Ya</option>
                                </select>
                            </div>
                            <div>
                                <label for="hypertension" class="form-label">Hipertensi</label>
                                <select class="form-field" id="hypertension" name="hypertension" required>
                                    <option value="0">Tidak</option>
                                    <option value="1">Ya</option>
                                </select>
                            </div>
                            <div>
                                <label for="cardiovascular" class="form-label">Penyakit Kardiovaskular</label>
                                <select class="form-field" id="cardiovascular" name="cardiovascular" required>
                                    <option value="0">Tidak</option>
                                    <option value="1">Ya</option>
                                </select>
                            </div>
                            <div>
                                <label for="depression" class="form-label">Depresi</label>
                                <select class="form-field" id="depression" name="depression" required>
                                    <option value="0">Tidak</option>
                                    <option value="1">Ya</option>
                                </select>
                            </div>
                            <div>
                                <label for="headInjury" class="form-label">Riwayat Cedera Kepala</label>
                                <select class="form-field" id="headInjury" name="headInjury" required>
                                    <option value="0">Tidak</option>
                                    <option value="1">Ya</option>
                                </select>
                            </div>
                            <div>
                                <label for="behavioralProblems" class="form-label">Masalah Perilaku</label>
                                <select class="form-field" id="behavioralProblems" name="behavioralProblems" required>
                                    <option value="0">Tidak ada</option>
                                    <option value="1">Ada masalah perilaku</option>
                                </select>
                                <p class="form-hint">Agitasi, agresi, atau perubahan mood.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="predict-panel" data-step-panel="4">
                    <div class="predict-card">
                        <div class="predict-card-header">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <i class="bi bi-lungs-fill text-secondary-blue"></i>
                                    Gaya Hidup & Tidur
                                </h2>
                                <p class="text-xs text-slate-500 mt-1">Kebiasaan sehari-hari yang memengaruhi risiko.</p>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">5 field</span>
                        </div>
                        <div class="predict-card-body space-y-5">
                            <div class="predict-grid-2">
                                <div>
                                    <label for="smoking" class="form-label">Status Merokok</label>
                                    <select class="form-field" id="smoking" name="smoking" required>
                                        <option value="0">Tidak merokok</option>
                                        <option value="1">Aktif merokok</option>
                                    </select>
                                </div>
                                <div>
                                    <label for="alcohol" class="form-label">Konsumsi Alkohol</label>
                                    <select class="form-field" id="alcohol" name="alcohol" required>
                                        <option value="0">Tidak / sesekali</option>
                                        <option value="1">Ya / rutin</option>
                                    </select>
                                </div>
                            </div>
                            <div class="range-container rounded-xl p-4 border border-slate-200 bg-slate-50/50">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="form-label mb-0">Aktivitas Fisik (jam/minggu)</span>
                                    <span id="valPhysical" class="range-value-display text-xs">4.5</span>
                                </div>
                                <input type="range" class="w-full accent-secondary-blue h-1.5 cursor-pointer" id="physicalActivity" name="physicalActivity" min="0" max="10" step="0.5" value="4.5" data-value-display="valPhysical">
                                <div class="flex justify-between form-hint mt-2 mb-0"><span>0 jam</span><span>10+ jam</span></div>
                            </div>
                            <div class="predict-grid-2">
                                <div class="range-container rounded-xl p-4 border border-slate-200 bg-slate-50/50">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="form-label mb-0">Kualitas Tidur</span>
                                        <span id="valSleep" class="range-value-display text-xs">7</span>
                                    </div>
                                    <input type="range" class="w-full accent-secondary-blue h-1.5 cursor-pointer" id="sleepQuality" name="sleepQuality" min="1" max="10" step="1" value="7" data-value-display="valSleep">
                                    <div class="flex justify-between form-hint mt-2 mb-0"><span>1 Buruk</span><span>10 Sangat baik</span></div>
                                </div>
                                <div class="range-container rounded-xl p-4 border border-slate-200 bg-slate-50/50">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="form-label mb-0">Kualitas Diet</span>
                                        <span id="valDiet" class="range-value-display text-xs">6</span>
                                    </div>
                                    <input type="range" class="w-full accent-secondary-blue h-1.5 cursor-pointer" id="dietQuality" name="dietQuality" min="1" max="10" step="1" value="6" data-value-display="valDiet">
                                    <div class="flex justify-between form-hint mt-2 mb-0"><span>1 Tidak sehat</span><span>10 Sehat</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="predict-action-bar">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <p class="text-[11px] text-slate-500 flex items-center gap-1.5">
                            <i class="bi bi-shield-check text-secondary-blue"></i>
                            Data diproses lokal dan disimpan sebagai riwayat prediksi.
                        </p>
                        <div class="flex items-center gap-3 justify-end">
                            <button type="button" id="predictPrevBtn"
                                class="px-5 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:border-secondary-blue hover:text-secondary-blue transition opacity-40 pointer-events-none">
                                <i class="bi bi-arrow-left mr-1"></i> Sebelumnya
                            </button>
                            <button type="button" id="predictNextBtn"
                                class="btn-primary-gradient px-6 py-2.5 rounded-xl text-sm font-semibold inline-flex items-center gap-2">
                                Selanjutnya <i class="bi bi-arrow-right"></i>
                            </button>
                            <button type="submit" id="predictSubmitBtn"
                                class="btn-primary-gradient px-6 py-2.5 rounded-xl text-sm font-semibold inline-flex items-center gap-2 hidden">
                                <i class="bi bi-cpu-fill"></i> Analisis Profil
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </section>

    <footer class="bg-slate-950 text-slate-400 py-10">
        <div class="page-container-wide text-center text-xs">
            &copy; 2026 NeuroCare AI &mdash; Kelompok APM, Universitas Andalas
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>

</html>
