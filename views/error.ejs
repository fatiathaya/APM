<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - NeuroCare AI</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-body-bg text-primary-dark font-outfit antialiased">
    <div class="min-h-screen flex items-center justify-center px-5">
        <div class="max-w-md w-full bg-white rounded-2xl border border-slate-100 shadow-md p-8 text-center">
            <div class="w-16 h-16 bg-rose-50 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-exclamation-triangle-fill text-rose-600 text-3xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2"><%= error || 'An Error Occurred' %></h2>
            <p class="text-slate-500 text-sm mb-4"><%= message || 'Something went wrong' %></p>
            <% if (details) { %>
                <div class="bg-slate-50 border border-slate-200 rounded-lg p-4 mb-6 text-left">
                    <p class="text-xs text-slate-600 font-mono"><%= details %></p>
                </div>
            <% } %>
            <a href="/predict" class="btn-primary-gradient py-2.5 px-6 rounded-lg text-sm inline-flex items-center gap-2">
                <i class="bi bi-arrow-left"></i>Back to Form
            </a>
        </div>
    </div>
</body>
</html>
